# DGX Spark connection settings — copy to .env and fill in your values.
# The .env file is loaded by scripts/remote_train.py.

# Tailscale hostname or IP of the DGX Spark unit.
DGX_HOST=msp-spark-01.tail521f18.ts.net

# SSH login credentials for the DGX Spark.
DGX_USER=
DGX_PASSWORD=

# Remote paths on the DGX Spark.
DGX_REMOTE_DIR=/home/${DGX_USER}/rubiks-solve
DGX_VENV_PATH=/home/${DGX_USER}/rubiks-venv

# PyTorch wheel index for CUDA 13 / aarch64 (DGX Spark default).
# Change only if you have a different CUDA version.
DGX_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu130
